// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}


enum AIPlan {
  FREE
  SUBSCRIPTION
  PAY_AS_YOU_GO
}

model Companies {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  logo       String?
  is_active  Boolean  @default(true)
  ai_plan    AIPlan   @default(FREE)
  token_usage Int      @default(0)
  credit_cost Float    @default(0)
  usage_limit Int     @default(10000) 
  created_at DateTime @default(now())

  units            Units[]
  users            Users[]
  cycles           Cycles[]
  kpi_dictionaries KPIDictionaries[]
  kpi_assignments  KPIAssignments[]
  kpi_records      KPIRecords[]
  objectives       Objectives[]
  key_results      KeyResults[]
  check_ins        CheckIns[]
  feedbacks        Feedbacks[]
  notifications    Notifications[]
  ai_usage_logs    AIUsageLogs[]
}

model Units {
  id         Int      @id @default(autoincrement())
  company_id Int
  name       String
  parent_id  Int?
  manager_id Int?
  path       Unsupported("ltree")
  deleted_at DateTime?
  created_at DateTime @default(now())

  company          Companies @relation(fields: [company_id], references: [id])
  parent           Units?    @relation("UnitHierarchy", fields: [parent_id], references: [id])
  children         Units[]   @relation("UnitHierarchy")
  manager          Users?    @relation("UnitManager", fields: [manager_id], references: [id])
  users            Users[]
  kpi_dictionaries KPIDictionaries[]
  kpi_assignments  KPIAssignments[]
  objectives       Objectives[]

  @@index([company_id])
}

enum UserRole {
  ADMIN
  ADMIN_COMPANY
  EMPLOYEE
}

model Users {
  id              Int      @id @default(autoincrement())
  company_id      Int?
  full_name       String
  email           String
  password        String
  avatar_url      String?
  job_title       String?
  role            UserRole
  unit_id         Int?
  is_active       Boolean  @default(true)
  deleted_at      DateTime?
  created_at      DateTime @default(now())

  company            Companies?     @relation(fields: [company_id], references: [id])
  unit               Units?        @relation(fields: [unit_id], references: [id])
  managed_units      Units[]       @relation("UnitManager")
  kpi_assignments    KPIAssignments[]
  objectives         Objectives[]
  approved_objectives Objectives[] @relation("ObjectiveApprover")
  check_ins          CheckIns[]
  feedbacks          Feedbacks[]
  notifications      Notifications[]
  ai_usage_logs      AIUsageLogs[]

  @@unique([email, company_id])
  @@index([company_id])
}

model Cycles {
  id         Int     @id @default(autoincrement())
  company_id Int
  name       String
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  is_locked  Boolean @default(false)

  company         Companies @relation(fields: [company_id], references: [id])
  kpi_assignments KPIAssignments[]
  objectives      Objectives[]

  @@index([company_id])
}

enum Visibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

model KPIDictionaries {
  id                Int     @id @default(autoincrement())
  company_id        Int?
  name              String
  description       String?
  unit              String
  evaluation_method String
  unit_id           Int?
  deleted_at        DateTime?

  company         Companies?     @relation(fields: [company_id], references: [id])
  unit_ref        Units?         @relation(fields: [unit_id], references: [id])
  kpi_assignments KPIAssignments[]

  @@index([company_id])
}

model KPIAssignments {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  parent_assignment_id Int?
  kpi_dictionary_id    Int
  cycle_id             Int
  owner_id             Int?
  unit_id              Int
  visibility           Visibility
  access_path          Unsupported("ltree")
  target_value         Float
  current_value        Float   @default(0)
  progress_percentage  Float   @default(0)
  deleted_at           DateTime?
  created_at           DateTime @default(now())

  company           Companies      @relation(fields: [company_id], references: [id])
  parent_assignment KPIAssignments? @relation("KPIAssignmentHierarchy", fields: [parent_assignment_id], references: [id])
  child_assignments KPIAssignments[] @relation("KPIAssignmentHierarchy")
  kpi_dictionary    KPIDictionaries  @relation(fields: [kpi_dictionary_id], references: [id])
  cycle             Cycles           @relation(fields: [cycle_id], references: [id])
  owner             Users?           @relation(fields: [owner_id], references: [id])
  unit              Units            @relation(fields: [unit_id], references: [id])
  kpi_records       KPIRecords[]

  @@index([company_id])
}

enum KPIStatus {
  ON_TRACK
  AT_RISK
  CRITICAL
}

model KPIRecords {
  id                  Int      @id @default(autoincrement())
  company_id          Int
  kpi_assignment_id   Int
  period_start        DateTime @db.Date
  period_end          DateTime @db.Date
  actual_value        Float
  progress_percentage Float
  status              KPIStatus
  trend               String
  created_at          DateTime @default(now())

  company        Companies     @relation(fields: [company_id], references: [id])
  kpi_assignment KPIAssignments @relation(fields: [kpi_assignment_id], references: [id])

  @@index([company_id])
}

enum ObjectiveProgressStatus {
  NOT_STARTED
  ON_TRACK
  WARNING
  DANGER
  COMPLETED
}

model Objectives {
  id                  Int      @id @default(autoincrement())
  company_id          Int
  title               String
  cycle_id            Int
  unit_id             Int?
  owner_id            Int?
  parent_objective_id Int?
  visibility          Visibility
  access_path         Unsupported("ltree")
  status              String
  approved_by         Int?
  progress_percentage Float   @default(0)
  deleted_at          DateTime?
  created_at          DateTime @default(now())

  company          Companies   @relation(fields: [company_id], references: [id])
  cycle            Cycles      @relation(fields: [cycle_id], references: [id])
  unit             Units?       @relation(fields: [unit_id], references: [id])
  owner            Users?      @relation(fields: [owner_id], references: [id])
  approver         Users?      @relation("ObjectiveApprover", fields: [approved_by], references: [id])
  parent_objective Objectives? @relation("ObjectiveHierarchy", fields: [parent_objective_id], references: [id])
  sub_objectives   Objectives[] @relation("ObjectiveHierarchy")
  key_results      KeyResults[]
  feedbacks        Feedbacks[]

  @@index([company_id])
}

model KeyResults {
  id                  Int     @id @default(autoincrement())
  company_id          Int
  objective_id        Int
  title               String
  target_value        Float
  current_value       Float   @default(0)
  unit                String
  weight              Float
  due_date            DateTime @db.Date
  progress_percentage Float   @default(0)
  deleted_at          DateTime?

  company   Companies  @relation(fields: [company_id], references: [id])
  objective Objectives @relation(fields: [objective_id], references: [id])
  check_ins CheckIns[]
  feedbacks Feedbacks[] 

  @@index([company_id])
}

model CheckIns {
  id                Int      @id @default(autoincrement())
  company_id        Int
  key_result_id     Int
  user_id           Int
  achieved_value    Float
  progress_snapshot Float
  evidence_url      String
  comment           String?
  created_at        DateTime @default(now())

  company    Companies  @relation(fields: [company_id], references: [id])
  key_result KeyResults @relation(fields: [key_result_id], references: [id])
  user       Users      @relation(fields: [user_id], references: [id])

  @@index([company_id])
}

enum FeedbackType {
  PRAISE
  CONCERN
  SUGGESTION
  QUESTION
  BLOCKER
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
  UNKNOWN
}

enum FeedbackStatus {
  ACTIVE
  RESOLVED
  FLAGGED
}

model Feedbacks {
  id           Int      @id @default(autoincrement())
  company_id   Int
  objective_id Int
  kr_tag_id    Int?
  user_id      Int
  parent_id    Int?
  content      String   @db.Text
  type         FeedbackType
  sentiment    FeedbackSentiment @default(UNKNOWN)
  status       FeedbackStatus @default(ACTIVE)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  company   Companies  @relation(fields: [company_id], references: [id])
  objective Objectives @relation(fields: [objective_id], references: [id])
  key_result KeyResults? @relation(fields: [kr_tag_id], references: [id])
  user      Users      @relation(fields: [user_id], references: [id])
  parent     Feedbacks?  @relation("FeedbackThread", fields: [parent_id], references: [id], onDelete: Cascade)
  replies    Feedbacks[] @relation("FeedbackThread")

  @@index([company_id])
  @@index([objective_id])
}

model Notifications {
  id           Int      @id @default(autoincrement())
  company_id   Int
  recipient_id Int
  type         String
  ref_type     String?
  ref_id       Int?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  company   Companies @relation(fields: [company_id], references: [id])
  recipient Users     @relation(fields: [recipient_id], references: [id])

  @@index([company_id])
}

enum AIUsageStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  BILLED
  EXCLUDED
}

model AIUsageLogs {
  id        Int      @id @default(autoincrement())
  company_id Int?
  user_id   Int?
  feature_name String
  model_name String
  input_tokens Int
  output_tokens Int
  total_tokens Int
  request_id String?
  credit_cost Float
  status      AIUsageStatus @default(PENDING)
  created_at DateTime @default(now())

  company   Companies? @relation(fields: [company_id], references: [id])
  user      Users?     @relation(fields: [user_id], references: [id])

  @@index([company_id])
}

view UnitPerformance {
  unit_id          Int    @unique
  company_id       Int
  name             String
  parent_id        Int?
  manager_id       Int?
  path             Unsupported("ltree")
  total_users      Int
  total_okrs       Int
  avg_okr_progress Float
  total_kpis       Int
  avg_kpi_progress Float

  @@map("unit_performance")
}